# ================================================================
# VARIÁVEIS DE AMBIENTE — Copie este arquivo para .env e preencha
# Configure também no painel da Vercel em Settings > Environment Variables
# ================================================================

# ── OpenAI ──────────────────────────────────────────────────────
# Chave da API OpenAI. Obtida em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Supabase ─────────────────────────────────────────────────────
# URL do projeto Supabase. Encontrada em: Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chave de Service Role (dá acesso total ao banco — mantenha secreta)
# Encontrada em: Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Segurança ────────────────────────────────────────────────────
# Senha de acesso ao painel admin. Use uma string aleatória forte (min 32 chars).
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=troque-por-string-aleatoria-de-32-chars-minimo

# Salt para HMAC do fingerprint de dispositivo. Nunca expor ao cliente.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FINGERPRINT_SALT=troque-por-outro-salt-aleatorio-32-chars

# ── Limites operacionais ─────────────────────────────────────────
# Máximo de chamadas reais à API da OpenAI por dia (UTC).
# Quando atingido, serve leitura de fallback estática sem custo.
# Calcule: MAX_BUDGET_MENSAL_USD / (0.000202 * 30)
# Exemplo: com limite de $3/mês → MAX = 495/dia → use 400 por segurança
MAX_AI_CALLS_PER_DAY=100

# ── Email Marketing (opcional — descomente quando for ativar) ────
# URL do webhook para integrar com Brevo, Mailchimp ou outra ferramenta.
# O payload enviado será: { name, email, sign, plan }
# EMAIL_WEBHOOK_URL=https://api.brevo.com/v3/contacts
# EMAIL_WEBHOOK_KEY=xkeysib-...

# ── Google AdSense (opcional — descomente quando for ativar) ─────
# ID da conta AdSense (formato ca-pub-XXXXXXXXXXXXXXXX)
# ADSENSE_CLIENT_ID=ca-pub-0000000000000000
